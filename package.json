{
  "name": "@mapatak/phone-input",
  "version": "2.0.0",
  "description": "Production-grade internationalized phone number input component for the Mapatak platform. Supports 196 countries with E.164 validation. Zero MUI — pure Tailwind + native React.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "zod": ">=3.0.0",
    "react-hook-form": ">=7.0.0"
  },
  "devDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.0",
    "react-hook-form": "^7.54.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.7.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0"
  },
  "keywords": [
    "phone-input",
    "e164",
    "mapatak",
    "international-phone",
    "react",
    "tailwind",
    "zod",
    "validation"
  ],
  "license": "UNLICENSED",
  "private": true
}
